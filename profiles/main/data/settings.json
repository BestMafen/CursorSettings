    // "editor.fontSize": 14,
    // #else
    // "editor.fontSize": 16,
    // #endif
    "editor.guides.bracketPairs": "active",
    "editor.inlayHints.enabled": "off",
    "editor.rulers": [
        110
    ],
    "editor.semanticTokenColorCustomizations": {
        "rules": {
            "annotation": {
                "foreground": "#FFCB6BFF",
                // "fontStyle": "bold",
            },
            "class": {
                "fontStyle": "bold",
                "foreground": "#C3E88DFF",
            },
            "comment": {
                "foreground": "#959DAAFF",
            },
            "enum": {
                "fontStyle": "bold",
                "foreground": "#C3E88DFF",
            },
            "enumMember": {
                "fontStyle": "bold italic",
                "foreground": "#FF7A50FF",
            },
            "function": {
                "foreground": "#82AAFFFF",
            },
            "keyword": {
                "foreground": "#C792EAFF",
                // "fontStyle": "bold",
            },
            "macro": {
                "fontStyle": "bold",
                "foreground": "#FFCB6BFF",
            },
            "method": {
                "foreground": "#82AAFFFF",
            },
            "number": {
                "foreground": "#6897BBFF",
            },
            "operator": {
                "foreground": "#89DDFFFF",
            },
            "parameter": {
                "foreground": "#797094FF",
            },
            "property": {
                "foreground": "#63FDDEFF",
            },
            "string": {
                "foreground": "#6A8759FF",
                // "fontStyle": "bold",
            },
            "type": {
                "fontStyle": "bold",
                "foreground": "#C3E88DFF",
            },
            "variable": {
                "foreground": "#EEFFE3FF",
            },
            "variable.declaration.definition.fileScope": {
                "foreground": "#0098FFFF",
            },
            "variable.declaration.definition.globalScope": {
                "foreground": "#0098FFFF",
            },
        },
    },
    "editor.suggest.filterGraceful": true,
    "editor.suggest.matchOnWordStartOnly": false,
    "editor.suggest.showWords": true,
