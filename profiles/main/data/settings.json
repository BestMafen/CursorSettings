{
    "editor.fontSize": 16,
    "editor.semanticTokenColorCustomizations": {
        "rules": {
            "class": {
                "foreground": "#C3E88DFF",
                "fontStyle": "bold",
            },
            "type": {
                "foreground": "#C3E88DFF",
                "fontStyle": "bold",
            },
            "property": {
                "foreground": "#63FDDEFF",
            },
            "variable.declaration.definition.fileScope": {
                "foreground": "#0098FFFF",
            },
            "variable.declaration.definition.globalScope": {
                "foreground": "#0098FFFF",
            },
            "variable": {
                "foreground": "#EEFFE3FF",
            },
            "parameter": {
                "foreground": "#797094FF",
            },
            "enumMember": {
                "foreground": "#FF7A50FF",
                "fontStyle": "bold italic",
            },
            "operator": {
                "foreground": "#89DDFFFF",
            },
        },
    },
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": [
                    "punctuation.definition.directive.c",
                    "keyword.control.directive.include.c",
                    "keyword.control.directive.conditional.c",
                    "keyword.other.import.dart",
                    "keyword.control.import.python",
                    "entity.name.function.decorator.python",
                ],
                "settings": {
                    "foreground": "#FFA0DBFF",
                    "fontStyle": "bold",
                },
            },
            {
                "scope": [
                    "entity.name.function.preprocessor.c",
                ],
                "settings": {
                    "foreground": "#FFCB6BFF",
                    "fontStyle": "bold",
                },
            },
            {
                "scope": [
                    "string.quoted.double.include.c",
                    "string.quoted.double.c",
                    "punctuation.definition.string.begin.c",
                    "punctuation.definition.string.end.c",
                    "string.quoted.single.dart",
                    "string.interpolated.double.dart",
                    "string.interpolated.single.dart",
                    "string.quoted.single.python",
                    "string.quoted.double.python",
                    "punctuation.definition.string.begin.python",
                    "punctuation.definition.string.end.python",
                    "string.quoted.single.yaml",
                    "string.quoted.double.yaml",
                    "punctuation.definition.string.begin.yaml",
                    "punctuation.definition.string.end.yaml",
                    "string.quoted.double.kotlin",
                    "string.quoted.multi.python",
                ],
                "settings": {
                    "foreground": "#6A8759FF",
                    "fontStyle": "bold",
                },
            },
            {
                "scope": [
                    "constant.character.escape",
                    "variable.string-escape.kotlin",
                ],
                "settings": {
                    "foreground": "#FFCB6BFF",
                },
            },
            {
                "scope": [
                    "comment.line.double-slash.c",
                    "comment.block.c",
                    "comment.line.double-slash.dart",
                    "comment.line.number-sign.python",
                    "punctuation.definition.comment.python",
                    "comment.line.number-sign.python",
                    "comment.line.number-sign.yaml",
                    "comment.line.double-slash.kotlin",
                ],
                "settings": {
                    "foreground": "#959DAAFF",
                    "fontStyle": "italic",
                },
            },
            {
                "scope": [
                    "entity.name.function.c",
                    "entity.name.function.dart",
                    "entity.name.function.python",
                    "meta.function-call.generic.python",
                    "entity.name.function.call.kotlin",
                    "entity.name.function.declaration.kotlin",
                ],
                "settings": {
                    "foreground": "#82AAFFFF",
                },
            },
            {
                "scope": [
                    "support.function.builtin.python",
                    "support.function.magic.python",
                ],
                "settings": {
                    "foreground": "#82AAFFFF",
                    "fontStyle": "italic"
                },
            },
            {
                "scope": [
                    "variable.parameter.preprocessor.c",
                    "meta.preprocessor.macro.c",
                    "variable.parameter.function.language.python",
                    "entity.other.inherited-class.python",
                    "variable.parameter.function-call.python",
                    "storage.type.format.python",
                    "meta.item-access.arguments.python",
                ],
                "settings": {
                    "foreground": "#797094FF",
                },
            },
            {
                "scope": [
                    "storage.type.built-in.primitive.c",
                    "storage.modifier.c",
                    "keyword.declaration.dart",
                    "keyword.control.dart",
                    "storage.modifier.dart",
                    "keyword.control.return.dart",
                    "storage.type.function.python",
                    "keyword.control.flow.python",
                    "storage.type.class.python",
                    "variable.language.special.self.python",
                    "variable.parameter.function.language.special.self.python",
                    "storage.type.annotation.dart",
                    "keyword.soft.kotlin",
                    "keyword.hard.package.kotlin",
                    "keyword.hard.class.kotlin",
                    "storage.modifier.other.kotlin",
                    "keyword.hard.kotlin",
                    "keyword.hard.object.kotlin",
                    "keyword.hard.fun.kotlin",
                    "variable.language.this.kotlin",
                    "punctuation.definition.decorator.python",
                    "entity.name.function.decorator.python",
                    "keyword.control.kotlin",
                ],
                "settings": {
                    "foreground": "#C792EAFF",
                    "fontStyle": "bold",
                },
            },
            {
                "scope": [
                    "constant.numeric.decimal.c",
                    "constant.numeric.dart",
                    "storage.type.number.python",
                    "constant.numeric.hex.python",
                    "constant.numeric.dec.python",
                    "constant.numeric.float.python",
                    "constant.numeric.decimal.kotlin",
                ],
                "settings": {
                    "foreground": "#6897BBFF",
                },
            },
            {
                "scope": [
                    "support.class.dart",
                    "storage.type.primitive.dart",
                    "support.type.python",
                    "entity.name.type.class.python",
                    "meta.function.parameters.python",
                    "support.type.exception.python",
                    "entity.name.type.class.kotlin",
                    "entity.name.type.kotlin",
                ],
                "settings": {
                    "foreground": "#C3E88DFF",
                    "fontStyle": "bold",
                },
            },
            {
                "scope": [
                    "variable.other.member.c",
                    "meta.attribute.python",
                    "string.unquoted.plain.out.yaml",
                ],
                "settings": {
                    "foreground": "#63FDDEFF",
                },
            },
            {
                "scope": [
                    "keyword.operator.assignment.dart",
                    "keyword.operator.assignment.arithmetic.dart",
                    "keyword.operator.comparison.dart",
                    "keyword.operator.closure.dart",
                    "punctuation.separator.annotation.result.python",
                    "keyword.operator.bitwise.python",
                    "keyword.operator.unpacking.arguments.python",
                    "keyword.operator.assignment.python",
                    "keyword.operator.comparison.python",
                    "storage.type.function.arrow.kotlin",
                    "keyword.operator.comparison.kotlin",
                    "keyword.operator.assignment.kotlin",
                    "keyword.operator.increment-decrement.dart",
                    "keyword.operator.ternary.dart",
                    "punctuation.dot.dart",
                    "keyword.operator.logical.dart",
                ],
                "settings": {
                    "foreground": "#89DDFFFF",
                },
            },
            {
                "scope": [
                    "constant.language.dart",
                    "constant.other.caps.python",
                    "constant.language.python",
                    "support.variable.magic.python",
                ],
                "settings": {
                   "foreground": "#FF7A50FF",
                    "fontStyle": "bold italic",
                },
            },
        ]
    },
    "workbench.tree.indent": 16,
    "clangd.path": "c:\\Users\\sma\\AppData\\Roaming\\Cursor\\User\\globalStorage\\llvm-vs-code-extensions.vscode-clangd\\install\\22.1.0\\clangd_22.1.0\\bin\\clangd.exe",
    "diffEditor.renderSideBySide": false,
    "python.createEnvironment.trigger": "off",
    "[python]": {
        "diffEditor.ignoreTrimWhitespace": false,
        "editor.defaultColorDecorators": "never",
        "editor.formatOnType": true,
        "editor.quickSuggestions": {
            "strings": true
        },
        "editor.wordBasedSuggestions": "off"
    },
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": "active",
    "files.autoSave": "onFocusChange",
    "diffEditor.hideUnchangedRegions.enabled": true,
    "editor.inlayHints.enabled": "off",
    "dart.inlayHints": false,
    "editor.rulers": [
        110
    ],
    "window.zoomLevel": 2.4,
    "cmake.buildDirectory": "${sourceDirectory}/cmake-build-debug",
    "cmake.cmakePath": "D:\\dev\\CMake\\bin\\cmake.exe",
    "explorer.autoReveal": false,
    "debug.onTaskErrors": "debugAnyway",
    "workbench.sideBar.location": "right",
    "gitlens.ai.model": "gitkraken",
    "gitlens.ai.gitkraken.model": "gemini:gemini-2.5-flash",
    "explorer.excludeGitIgnore": false,
    "search.useIgnoreFiles": false,
    "git.repositoryScanMaxDepth": 4,
    "git.autoRepositoryDetection": "subFolders",
    "workbench.colorTheme": "IDX VS Code - Default Dark Syntax",
    "explorer.confirmPasteNative": false,
    "editor.suggest.matchOnWordStartOnly": false,
    "editor.suggest.filterGraceful": true,
    "editor.wordBasedSuggestions": "allDocuments",
    "editor.suggest.showWords": true,
    "workbench.list.openMode": "doubleClick",
    "syncSettings.resources": ["extensions", "keybindings", "settings", "snippets"],
    "syncSettings.keybindingsPerPlatform": true,
}
