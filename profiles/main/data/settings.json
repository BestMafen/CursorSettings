{
    "editor.fontSize": 16,
    "editor.semanticTokenColorCustomizations": {
        "rules": {
            "class": {
                "foreground": "#C3E88DFF",
                "fontStyle": "bold",
            },
            "type": {
                "foreground": "#C3E88DFF",
                "fontStyle": "bold",
